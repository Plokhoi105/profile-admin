# Panel login. Use a unique password; the panel is still private through Tailscale.
ADMIN_USER=alex
ADMIN_PASSWORD=replace-with-a-long-random-password

# Vision
VISION_TOKEN=replace-with-vision-token
VISION_API_BASE=https://api.browser.vision/api/v1
VISION_FOLDER_ID=replace-with-vision-folder-id

# IPRoyal
IPROYAL_API_TOKEN=replace-with-iproyal-token
IPROYAL_API_BASE=https://resi-api.iproyal.com/v1
IPROYAL_SUBUSER=replace-with-iproyal-subuser
IPROYAL_HOSTNAME=geo.iproyal.com
IPROYAL_LIFETIME=168h

# Scamalytics
SCAMALYTICS_USER=replace-with-scamalytics-user
SCAMALYTICS_API_KEY=replace-with-scamalytics-api-key

# Telegram
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_ALLOWED_USER_IDS=123456789
